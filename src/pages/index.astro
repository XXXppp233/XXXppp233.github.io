---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Interface for a left-side fading hero image:
// 1. Add your image under src/assets/
// 2. Import it here, for example: import HeroFadeImage from '../assets/hero-fade.jpg';
// 3. Set: const heroFadeImage = HeroFadeImage.src;
const heroFadeImage = '';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero panel">
				<div
					class:list={['hero-copy', { 'has-fade-image': heroFadeImage }]}
					style={heroFadeImage ? `--hero-fade-image: url('${heroFadeImage}')` : undefined}
				>
					<p class="eyebrow">1930 Cartoon Style</p>
					<h1>Ink & Wash Studio</h1>
					<p>
						本博客小心翼翼地采用了1930年代的卡通风格，旨在为读者提供一种独特的视觉体验。通过厚重的线条、柔和的水彩效果和充满弹性的动画营造出一种既怀旧又充满活力的氛围，让每一篇文章都像是一幅生动的插图，带领读者进入一个充满创意和想象力的世界。
					</p>
					<div class="hero-actions">
						<a class="button primary" href="/blog">Read the reels</a>
						<a class="button" href="/about">Meet the artist</a>
						<a class="button mahjong" href="https://mahjong.wepayto.win">Play MahJong</a>
					</div>
				</div>

			</section>
			<section class="feature-grid">
				<article class="panel feature">
					<span>01</span>
					<h2>Ink Lines</h2>
					<p>Thick outlines, playful silhouettes, and imperfect curves that feel drawn by hand.</p>
				</article>
				<article class="panel feature">
					<span>02</span>
					<h2>Watercolor</h2>
					<p>Soft washes, paper grain, muted pigments, and backgrounds that avoid flat color.</p>
				</article>
				<article class="panel feature">
					<span>03</span>
					<h2>Rubber Motion</h2>
					<p>Subtle squash, lifted buttons, and bouncy entrances without adding JavaScript.</p>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	main {
		width: 1120px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.72fr);
		gap: 2rem;
		align-items: center;
		min-height: 560px;
		padding: clamp(1.4rem, 5vw, 4rem);
	}

	.hero-copy,
	.hero-visual {
		position: relative;
		z-index: 1;
	}

	.hero-copy {
		isolation: isolate;
	}

	.hero-copy.has-fade-image::before {
		position: absolute;
		inset: -2rem -3rem -2rem -2rem;
		z-index: -1;
		content: "";
		background-image: var(--hero-fade-image);
		background-repeat: no-repeat;
		background-position: left center;
		background-size: min(58vw, 760px) auto;
		filter: grayscale(1) contrast(1.08);
		opacity: 0.34;
		-webkit-mask-image: linear-gradient(90deg, black 0%, rgba(0, 0, 0, 0.8) 34%, transparent 82%);
		mask-image: linear-gradient(90deg, black 0%, rgba(0, 0, 0, 0.8) 34%, transparent 82%);
	}

	.hero p:not(.eyebrow) {
		max-width: 42rem;
		color: rgb(var(--gray));
		font-size: 1.08em;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85em;
		margin-top: 1.8em;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3.1em;
		padding: 0.75em 1.15em;
		color: var(--ink);
		font-weight: 700;
		text-decoration: none;
		background: var(--paper-light);
		border: 3px solid var(--ink);
		border-radius: 999px 820px 930px 760px;
		box-shadow: 5px 6px 0 rgba(var(--ink-rgb), 0.18);
	}

	.button:hover {
		transform: translateY(-3px) rotate(-1deg);
		box-shadow: 7px 9px 0 rgba(var(--ink-rgb), 0.2);
	}

	.button.primary {
		color: var(--paper-light);
		background: var(--paint-red);
	}
	.button.mahjong {
		background: var(--paint-gold);
	}

	.hero-visual {
		display: grid;
		place-items: center;
		min-height: 360px;
	}

	.toon-card {
		position: relative;
		width: min(100%, 340px);
		aspect-ratio: 0.78;
		padding: 1.2rem;
		background:
			radial-gradient(circle at 35% 22%, rgba(255, 255, 255, 0.72), transparent 5.8rem),
			radial-gradient(circle at 82% 78%, rgba(80, 80, 76, 0.18), transparent 9rem),
			linear-gradient(180deg, rgba(230, 230, 224, 0.88), rgba(247, 247, 241, 0.96));
		border: 5px solid var(--ink);
		border-radius: 42px 34px 48px 32px;
		box-shadow: 12px 13px 0 rgba(var(--ink-rgb), 0.2);
		transform: rotate(2deg);
	}

	.caption {
		position: absolute;
		z-index: 2;
		color: var(--paper-light);
		font-size: 0.74em;
		font-weight: 700;
		letter-spacing: 0.08em;
		background: var(--paint-brown);
		border: 3px solid var(--ink);
		border-radius: 999px;
		padding: 0.25em 0.7em;
	}

	.caption {
		right: 1.4rem;
		bottom: 1.4rem;
	}

	.moon {
		position: absolute;
		top: 5rem;
		right: 3rem;
		width: 5.4rem;
		height: 5.4rem;
		background: var(--paint-gold);
		border: 4px solid var(--ink);
		border-radius: 50%;
		box-shadow: inset -10px -9px 0 rgba(var(--ink-rgb), 0.12);
	}

	.character {
		position: absolute;
		left: 50%;
		bottom: 4.4rem;
		width: 10.6rem;
		height: 12rem;
		background: var(--paper-light);
		border: 5px solid var(--ink);
		border-radius: 48% 48% 38% 42%;
		box-shadow: inset -13px -8px 0 rgba(var(--ink-rgb), 0.08);
		transform: translateX(-50%) rotate(-3deg);
	}

	.character::before,
	.character::after {
		position: absolute;
		top: 58%;
		width: 3rem;
		height: 4.8rem;
		content: "";
		background: var(--paint-red);
		border: 4px solid var(--ink);
		border-radius: 999px;
	}

	.character::before {
		left: -2.1rem;
		transform: rotate(28deg);
	}

	.character::after {
		right: -2.1rem;
		transform: rotate(-28deg);
	}

	.eye {
		position: absolute;
		top: 3.5rem;
		width: 1.4rem;
		height: 2rem;
		background: var(--ink);
		border-radius: 50%;
	}

	.eye::after {
		position: absolute;
		top: 0.25rem;
		left: 0.25rem;
		width: 0.35rem;
		height: 0.5rem;
		content: "";
		background: white;
		border-radius: 50%;
	}

	.eye.left {
		left: 3rem;
	}

	.eye.right {
		right: 3rem;
	}

	.smile {
		position: absolute;
		top: 6.2rem;
		left: 50%;
		width: 3.3rem;
		height: 1.5rem;
		border-bottom: 4px solid var(--ink);
		border-radius: 0 0 999px 999px;
		transform: translateX(-50%);
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin-top: 1rem;
	}

	.feature {
		padding: 1.4rem;
	}

	.feature > * {
		position: relative;
		z-index: 1;
	}

	.feature span {
		color: var(--paint-red);
		font-weight: 700;
		letter-spacing: 0.1em;
	}

	.feature h2 {
		margin-top: 0.6rem;
		font-size: 1.55rem;
	}

	.feature p {
		color: rgb(var(--gray));
	}

	@media (max-width: 820px) {
		.hero,
		.feature-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
		}
	}
</style>
